{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/agenda.php"
    },
    {
      "source": "/index.php",
      "destination": "/api/index.php"
    },
    {
      "source": "/agenda.php",
      "destination": "/api/agenda.php"
    }
  ]
}
